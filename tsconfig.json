{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"lib": ["ES2022"],
		"outDir": "./dist",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"moduleResolution": "bundler",
		"types": ["node", "vitest/globals"]
	},
	"include": [
		"worker-configuration.d.ts",
		"src/**/*",
		"vitest.config.ts"
	],
	"exclude": [
		"node_modules",
		"dist",
		"src/worker-auth.ts",
		"src/worker-simple.ts",
		"src/worker-multiuser.ts",
		"src/clerk-auth.ts",
		"src/clerk-handler.ts",
		"src/worker-auth.test.ts"
	]
}
