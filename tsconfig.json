{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "types": ["node", "vitest/globals", "vite/client"],
    "jsx": "react-jsx"
  },
  "include": ["worker-configuration.d.ts", "src/**/*", "vitest.config.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/__tests__/**/*",
    "src/worker-auth.ts",
    "src/worker-simple.ts",
    "src/worker-multiuser.ts",
    "src/clerk-auth.ts",
    "src/clerk-handler.ts",
    "src/worker-auth.test.ts",
    "src/calendar-manager.ts",
    "src/server-setup.ts",
    "src/index.ts"
  ]
}
