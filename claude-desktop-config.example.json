{
  "mcpServers": {
    "ical-mcp": {
      "command": "node",
      "args": ["/absolute/path/to/ical-mcp/dist/index.js"],
      "env": {
        "CALENDAR_URL": "https://example.com/calendar.ics",
        "CALENDAR_NAME": "Work Calendar",
        "CALENDAR_REFRESH_INTERVAL": "60"
      }
    }
  }
}
