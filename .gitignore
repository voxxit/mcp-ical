### Universal ###
# Common files that should be ignored in all projects

# macOS system files
.DS_Store

# Logs
*.log
# Temporary files
*.tmp
*~

*.bak
# Environment files (containing secrets, API keys, credentials)
.env
.envrc
*.env
.env.*
.dev.vars

# Local configuration that shouldn't be shared
*.local

# Cloudflare
.wrangler/
dist-worker/

### Typescript ###
# typescript specific files

*.tsbuildinfo
node_modules/
dist/

coverage/
