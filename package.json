{
  "name": "@voxxit/mcp-ical",
  "version": "1.0.3",
  "type": "module",
  "main": "dist/worker.js",
  "scripts": {
    "build": "vite build",
    "build:worker": "tsc --project tsconfig.worker.json",
    "dev": "vite dev",
    "dev:wrangler": "wrangler dev",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "deploy:preview": "npm run build && wrangler deploy --env preview",
    "inspect": "npx @modelcontextprotocol/inspector@latest",
    "setup:kv": "wrangler kv:namespace create CALENDAR_CACHE && wrangler kv:namespace create CALENDAR_CACHE --preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "types": "wrangler types",
    "prepublishOnly": "npm run build && npm test",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "ical",
    "calendar",
    "modelcontextprotocol",
    "claude"
  ],
  "author": "Josh Delsman",
  "license": "MIT",
  "description": "Model Context Protocol server for iCalendar (.ics) subscriptions with local caching and calendar event queries",
  "repository": {
    "type": "git",
    "url": "https://github.com/voxxit/mcp-ical.git"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.11.7",
    "@modelcontextprotocol/sdk": "^1.17.2",
    "@stytch/react": "^19.8.0",
    "@stytch/vanilla-js": "^5.32.0",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^5.0.1",
    "agents": "^0.0.113",
    "axios": "^1.11.0",
    "hono": "^4.9.4",
    "jose": "^6.0.13",
    "node-cache": "^5.1.2",
    "node-ical": "^0.20.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2",
    "rrule": "^2.8.1",
    "stytch": "^12.31.0",
    "temporal-polyfill": "^0.3.0",
    "zod": "^3.25.76"
  },
  "_comments": {
    "temporal-polyfill": "Required runtime polyfill for Temporal API in Node.js environments. Used in calendar-manager.ts and timezone-date-manager.ts for robust date/time operations."
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.2",
    "@cloudflare/workers-types": "^4.20250121.1",
    "@types/nock": "^10.0.3",
    "@types/node": "^24.2.1",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "happy-dom": "^18.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "nock": "^14.0.9",
    "prettier": "3.6.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "wrangler": "^4.32.0"
  }
}
